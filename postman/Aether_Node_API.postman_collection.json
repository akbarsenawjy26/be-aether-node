    {
      "name": "🔐 Auth (Public)",
      "item": [
        {
          "name": "POST /auth/register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 or 409', function() {",
                  "    pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
                  "});",
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.data && jsonData.data.guid) {",
                  "        pm.collectionVariables.set('userGuid', jsonData.data.guid);",
                  "    }",
                  "    if (jsonData.data && jsonData.data.access_token) {",
                  "        pm.collectionVariables.set('accessToken', jsonData.data.access_token);",
                  "    }",
                  "    if (jsonData.data && jsonData.data.refresh_token) {",
                  "        pm.collectionVariables.set('refreshToken', jsonData.data.refresh_token);",
                  "    }",
                  "    console.log('Registration successful');",
                  "} else {",
                  "    console.log('User already exists - this is ok for re-runs');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"admin@aether.local\",\n    \"password\": \"admin123\",\n    \"first_name\": \"Admin\",\n    \"last_name\": \"Aether\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "Register new user account"
          },
          "response": []
        },
        {
          "name": "POST /auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function() {",
